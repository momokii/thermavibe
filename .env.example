# =============================================================================
# VibePrint OS - Development Environment Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
# =============================================================================
# All other settings have defaults and are managed via the admin panel
# at http://localhost:5173/admin after first run.
# =============================================================================

# === Application ===
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=postgresql+asyncpg://thermavibe:thermavibe@postgres:5432/thermavibe

# === Admin ===
ADMIN_PIN=1234

# === Hardware ===
CAMERA_DEVICE_INDEX=0

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# === Digital Sharing (all optional — unset = today's loopback-only behavior) ===
# PUBLIC_BASE_URL — public hostname for share URLs. When set, the QR code on the
# reveal screen encodes an absolute URL (https://your-kiosk.yourdomain.com/...).
# Unset = QR encodes a relative path (only works when phone and kiosk share an origin).
# Example: PUBLIC_BASE_URL=https://kiosk.yourdomain.com
PUBLIC_BASE_URL=

# BIND_HOST — what network interface the app port binds to.
#   127.0.0.1 (default) = loopback only — no other device can reach the kiosk
#   0.0.0.0             = all interfaces — phones on the same LAN can hit it directly
# Override only for the LAN-only fallback (no Cloudflare Tunnel). 0.0.0.0 exposes
# the admin API to anyone on the LAN — use only on trusted networks.
BIND_HOST=127.0.0.1

# TUNNEL_TOKEN — Cloudflare Tunnel token. Required only if you run `make dev-tunnel`
# or `make prod-tunnel`. Create at https://one.dash.cloudflare.com/ → Tunnels.
TUNNEL_TOKEN=

# Share landing page branding is configured at /admin/sharing after first boot
# (not via env vars).
