# === Application ===
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true

# === Database ===
# For Docker: use 'postgres' as hostname. For local dev: use 'localhost'.
DATABASE_URL=postgresql+asyncpg://thermavibe:thermavibe@postgres:5432/thermavibe

# === AI Providers ===
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
AI_MODEL=gpt-4o
AI_SYSTEM_PROMPT="You are a witty vibe reader. Analyze the person in the photo and generate a fun, personalized reading about their aura, energy, and vibe. Keep it lighthearted, positive, and shareable. Response should be 2-3 short paragraphs."

# === Payment (QRIS) ===
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=mock
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_API_KEY=
PAYMENT_AMOUNT=5000
PAYMENT_CURRENCY=IDR
PAYMENT_TIMEOUT_SECONDS=120

# === Thermal Printer ===
PRINTER_VENDOR_ID=0x04b8
PRINTER_PRODUCT_ID=0x0e15
PRINTER_PAPER_WIDTH=384
PRINTER_AUTO_DETECT=true
PRINTER_HOTPLUG_INTERVAL_SECONDS=30

# === Camera ===
CAMERA_DEVICE_INDEX=0
CAMERA_RESOLUTION_WIDTH=1280
CAMERA_RESOLUTION_HEIGHT=720

# === Admin ===
ADMIN_PIN=1234
ADMIN_SESSION_TTL_HOURS=24

# === CORS & Rate Limiting ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

