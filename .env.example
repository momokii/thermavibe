# =============================================================================
# VibePrint OS - Development Environment Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
# =============================================================================
# Settings here are DEPLOYMENT-TIME only. Runtime settings (AI, payment,
# photobooth, printer hardware, kiosk timings) are managed via the admin
# panel at http://localhost:5173/admin and stored in the database.
# =============================================================================

# === Application ===
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# === Database ===
# For Docker: use 'postgres' as hostname. For local dev: use 'localhost'.
DATABASE_URL=postgresql+asyncpg://thermavibe:thermavibe@postgres:5432/thermavibe

# === Admin ===
ADMIN_PIN=1234
ADMIN_SESSION_TTL_HOURS=24

# === Hardware Detection (machine-specific, not in admin panel) ===
PRINTER_AUTO_DETECT=true
PRINTER_HOTPLUG_INTERVAL_SECONDS=30
CAMERA_DEVICE_INDEX=0

# === AI Provider Keys (initial seed, then managed via admin panel) ===
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# === Payment Keys (initial seed, then managed via admin panel) ===
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=mock
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_API_KEY=

# === Printer Hardware (initial seed, then managed via admin panel) ===
PRINTER_VENDOR_ID=0x04b8
PRINTER_PRODUCT_ID=0x0e15

# === CORS & Rate Limiting ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
