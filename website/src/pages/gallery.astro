---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import GalleryFilter from '../components/GalleryFilter.tsx';
import GalleryGrid from '../components/GalleryGrid.astro';
---

<BaseLayout title="Gallery — VibePrint OS">
  <div class="section">
    <div class="section-inner">
      <SectionHeading
        title="Gallery"
        subtitle="See what VibePrint OS can create — from AI personality readings to multi-photo strips."
      />

      <div style="display: flex; justify-content: center; margin-bottom: 3rem;">
        <GalleryFilter client:load />
      </div>

      <GalleryGrid />

      <div style="margin-top: 4rem; text-align: center;">
        <p style="font-size: 0.8125rem; color: var(--text-3);">
          These are placeholder cards. Replace with real images in
          <code style="font-size: 0.8125em; background: var(--bg-elevated); padding: 2px 6px; border-radius: 4px; color: var(--accent);">public/images/gallery/</code>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
