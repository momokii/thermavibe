---
import { docSections } from '../data/nav';

interface Props {
  currentPage: string;
}

const { currentPage } = Astro.props;
---

<!-- Desktop sidebar -->
<aside style="display: none; width: 18rem; flex-shrink: 0; position: sticky; top: 4rem; height: calc(100vh - 4rem); overflow-y: auto; padding: 2rem 1.5rem 2rem 0;" class="lg-sidebar">
  <nav style="display: flex; flex-direction: column; gap: 2rem;">
    {docSections.map((section) => (
      <div>
        <p style="font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-3); margin-bottom: 0.75rem;">
          {section.title}
        </p>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.125rem;">
          {section.items.map((item) => {
            const isActive = currentPage === item.href;
            return (
              <li>
                <a
                  href={item.href}
                  style={isActive
                    ? 'display: block; padding: 0.5rem 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; text-decoration: none; color: var(--text); background: var(--accent-dim); font-weight: 500;'
                    : 'display: block; padding: 0.5rem 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; text-decoration: none; color: var(--text-3); transition: color 200ms;'}
                  onMouseEnter={!isActive ? "this.style.color='var(--text-2)'" : ""}
                  onMouseLeave={!isActive ? "this.style.color='var(--text-3)'" : ""}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>

  <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
    <a
      href="https://github.com/momokii/thermavibe"
      target="_blank"
      rel="noopener noreferrer"
      style="font-size: 0.75rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.375rem; color: var(--text-3); transition: color 200ms;"
    >
      Edit on GitHub
      <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
      </svg>
    </a>
  </div>
</aside>

<!-- Mobile doc nav toggle -->
<div style="margin-bottom: 2rem;" class="lg-hide">
  <details>
    <summary
      style="cursor: pointer; padding: 0.75rem 1rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 500; display: flex; align-items: center; gap: 0.5rem; list-style: none; background: var(--bg-card); border: 1px solid var(--border); color: var(--text);"
    >
      <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      Navigation
      <svg style="width: 16px; height: 16px; margin-left: auto;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <nav style="margin-top: 0.5rem; padding: 1rem; border-radius: 0.5rem; background: var(--bg-card); border: 1px solid var(--border);">
      {docSections.map((section) => (
        <div style="margin-bottom: 1.5rem;">
          <p style="font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-3); margin-bottom: 0.5rem;">
            {section.title}
          </p>
          <ul style="list-style: none;">
            {section.items.map((item) => {
              const isActive = currentPage === item.href;
              return (
                <li>
                  <a
                    href={item.href}
                    style={isActive
                      ? 'display: block; padding: 0.5rem 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; text-decoration: none; color: var(--accent); font-weight: 500;'
                      : 'display: block; padding: 0.5rem 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; text-decoration: none; color: var(--text-3);'}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </nav>
  </details>
</div>

<style>
  @media (min-width: 1024px) {
    .lg-sidebar { display: block !important; }
    .lg-hide { display: none !important; }
  }
</style>
