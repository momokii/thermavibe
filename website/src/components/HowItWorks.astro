---
const steps = [
  {
    number: '01',
    title: 'Plug In Hardware',
    description: 'Connect any USB webcam and ESC/POS thermal printer to a Linux machine.',
  },
  {
    number: '02',
    title: 'Deploy with Docker',
    description: 'One command to get everything running. No manual configuration required.',
  },
  {
    number: '03',
    title: 'Configure via Admin',
    description: 'Choose AI provider, set pricing, and customize templates from a web dashboard.',
  },
  {
    number: '04',
    title: 'Start Earning',
    description: 'Guests walk up, pay via QRIS, get their photo and AI reading printed.',
  },
];
---

<section class="section">
  <div class="section-inner">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 4rem;">
      <p class="section-label">Setup</p>
      <h2 class="section-title">Up and running in 4 steps</h2>
      <p class="section-desc" style="margin: 1rem auto 0;">
        No proprietary hardware. No vendor lock-in. No recurring fees.
      </p>
    </div>

    <!-- Steps -->
    <div style="display: grid; grid-template-columns: repeat(1, 1fr); gap: 2rem;">
      {steps.map((step) => (
        <div class="card" style="display: flex; align-items: flex-start; gap: 1.25rem;">
          <span style="font-family: 'Outfit', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--accent); background: var(--accent-dim); padding: 0.375rem 0.75rem; border-radius: 0.5rem; white-space: nowrap; flex-shrink: 0;">
            {step.number}
          </span>
          <div>
            <h3 style="font-size: 1.0625rem; font-weight: 600; color: var(--text); margin-bottom: 0.375rem;">
              {step.title}
            </h3>
            <p style="font-size: 0.9375rem; color: var(--text-3); line-height: 1.6;">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <style>
      @media (min-width: 768px) {
        .section-inner > div:nth-child(2) {
          grid-template-columns: repeat(2, 1fr);
        }
      }
    </style>
  </div>
</section>
