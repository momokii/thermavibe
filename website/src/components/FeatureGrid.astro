---
import { features } from '../data/features';
import FeatureCard from './FeatureCard.astro';
---

<section class="section" style="border-top: 1px solid var(--border);">
  <div class="section-inner">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 4rem;">
      <p class="section-label">Features</p>
      <h2 class="section-title">Everything you need to run a photobooth</h2>
      <p class="section-desc" style="margin: 1rem auto 0;">
        AI analysis, payments, printing, analytics — all in one open-source package.
      </p>
    </div>

    <!-- Grid -->
    <div style="display: grid; grid-template-columns: repeat(1, 1fr); gap: 1.25rem;">
      {features.map((feature, i) => (
        <FeatureCard
          title={feature.title}
          description={feature.description}
          icon={feature.icon}
        />
      ))}
    </div>

    <!-- Responsive: on md+, use proper grid -->
    <style>
      @media (min-width: 768px) {
        .section-inner > div:nth-child(2) {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (min-width: 1024px) {
        .section-inner > div:nth-child(2) {
          grid-template-columns: repeat(3, 1fr);
        }
      }
    </style>
  </div>
</section>
