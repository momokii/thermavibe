---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div style="text-align: center; margin-bottom: 4rem;">
  <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; letter-spacing: -0.02em; color: var(--text); line-height: 1.15;">
    {title}
  </h2>
  {subtitle && (
    <p style="font-size: 1.125rem; color: var(--text-3); margin-top: 1rem; max-width: 36rem; margin-left: auto; margin-right: auto; line-height: 1.7;">
      {subtitle}
    </p>
  )}
</div>
