---
interface Props {
  id: string;
  type: string;
  title: string;
  description: string;
  image: string;
}

const { id, type, title, description, image } = Astro.props;
---

<div
  class="gallery-item"
  data-type={type}
  style="border-radius: 0.75rem; overflow: hidden; border: 1px solid var(--border); background: var(--bg-elevated);"
>
  <div style="aspect-ratio: 16/10; overflow: hidden; position: relative; background: var(--bg-elevated);">
    <img
      src={image}
      alt={title}
      loading="lazy"
      style="width: 100%; height: 100%; object-fit: cover; display: block;"
    />
    <span
      style="position: absolute; top: 0.75rem; left: 0.75rem; font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.25rem 0.625rem; border-radius: 9999px; background: rgba(0,0,0,0.6); color: rgba(255,255,255,0.8); backdrop-filter: blur(4px);"
    >
      {type === 'vibe-check' ? 'Vibe Check' : type === 'photobooth' ? 'Photobooth' : 'General'}
    </span>
  </div>

  <div style="padding: 1.25rem;">
    <p style="font-size: 0.9375rem; font-weight: 600; color: var(--text); line-height: 1.4;">{title}</p>
    <p style="font-size: 0.8125rem; color: var(--text-3); margin-top: 0.375rem; line-height: 1.5;">{description}</p>
  </div>
</div>
