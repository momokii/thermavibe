---
import GradientText from './GradientText.astro';
---

<section class="relative flex flex-col items-center justify-center text-center" style="min-height: 100vh; padding: 6rem 1.5rem 4rem;">

  <div style="max-width: 56rem; margin: 0 auto;">
    <!-- Pill badge -->
    <div
      style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 1rem; border-radius: 9999px; font-size: 0.8125rem; font-weight: 500; margin-bottom: 2rem; background: var(--accent-dim); color: var(--accent); border: 1px solid var(--accent-border);"
    >
      <span style="width: 6px; height: 6px; border-radius: 50%; background: #4ade80;"></span>
      Open source &middot; MIT License
    </div>

    <!-- Headline -->
    <h1 style="font-size: clamp(2.75rem, 6vw, 4.5rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.05; color: var(--text);">
      AI-Powered Photobooth.<br />
      <GradientText>Open Source.</GradientText>
    </h1>

    <!-- Subtitle -->
    <p style="font-size: 1.25rem; color: var(--text-2); margin-top: 1.75rem; max-width: 32rem; margin-left: auto; margin-right: auto; line-height: 1.7;">
      Turn any webcam and thermal printer into a smart photobooth kiosk. Deploy in minutes. No licensing fees.
    </p>

    <!-- CTAs -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 2.5rem;">
      <a href="/docs/getting-started" class="btn-primary">
        Get Started
        <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
      <a href="https://github.com/momokii/thermavibe" target="_blank" rel="noopener noreferrer" class="btn-ghost">
        <svg style="width: 18px; height: 18px;" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </div>

  <!-- Preview terminal -->
  <div style="margin-top: 5rem; max-width: 48rem; width: 100%; padding: 0 1rem;">
    <div
      style="border-radius: 1rem; border: 1px solid var(--border); overflow: hidden; background: var(--bg-card); box-shadow: 0 25px 60px -12px rgba(0,0,0,0.5);"
    >
      <!-- Terminal bar -->
      <div style="display: flex; align-items: center; gap: 6px; padding: 0.875rem 1.25rem; background: var(--bg-elevated); border-bottom: 1px solid var(--border);">
        <span style="width: 12px; height: 12px; border-radius: 50%; background: #ef4444;"></span>
        <span style="width: 12px; height: 12px; border-radius: 50%; background: #eab308;"></span>
        <span style="width: 12px; height: 12px; border-radius: 50%; background: #22c55e;"></span>
        <span style="margin-left: 0.75rem; font-size: 0.75rem; color: var(--text-3); font-family: monospace;">~/thermavibe</span>
      </div>
      <!-- Terminal content -->
      <div style="padding: 2rem; font-family: monospace; font-size: 0.875rem; line-height: 2;">
        <div><span style="color: var(--text-3);">$</span> <span style="color: #4ade80;">git clone</span> https://github.com/momokii/thermavibe.git</div>
        <div><span style="color: var(--text-3);">$</span> <span style="color: #4ade80;">cd</span> thermavibe && cp .env.example .env</div>
        <div><span style="color: var(--text-3);">$</span> <span style="color: #4ade80;">docker compose up -d</span></div>
        <div style="margin-top: 0.5rem; color: var(--text-3);">✓ VibePrint OS running at http://localhost:8000</div>
      </div>
    </div>
  </div>
</section>
