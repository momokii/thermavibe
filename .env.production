# =============================================================================
# VibePrint OS - Production Environment Configuration
# =============================================================================
# Copy to .env on the kiosk machine:  cp .env.production .env
# Then edit the values marked with [CHANGE ME].
# =============================================================================

# === Application ===
APP_ENV=production
APP_SECRET_KEY=[CHANGE ME - generate with: python -c "import secrets; print(secrets.token_hex(32))"]
APP_DEBUG=false
LOG_LEVEL=WARNING

# === Database ===
# Matches docker-compose.yml defaults. Change only if you customized them.
DATABASE_URL=postgresql+asyncpg://thermavibe:thermavibe@postgres:5432/thermavibe
POSTGRES_DB=thermavibe
POSTGRES_USER=thermavibe
POSTGRES_PASSWORD=[CHANGE ME - set a secure database password]

# === AI Providers ===
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_MODEL=gpt-4o
AI_SYSTEM_PROMPT="You are a witty vibe reader."

# === Payment (QRIS) ===
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=mock
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
PAYMENT_AMOUNT=5000
PAYMENT_CURRENCY=IDR
PAYMENT_TIMEOUT_SECONDS=120

# === Thermal Printer ===
PRINTER_VENDOR_ID=0x04b8
PRINTER_PRODUCT_ID=0x0e15
PRINTER_PAPER_WIDTH=384
PRINTER_AUTO_DETECT=true
PRINTER_HOTPLUG_INTERVAL_SECONDS=30

# === Camera ===
CAMERA_DEVICE_INDEX=0
CAMERA_RESOLUTION_WIDTH=1280
CAMERA_RESOLUTION_HEIGHT=720

# === Admin ===
ADMIN_PIN=[CHANGE ME - set a secure PIN]
ADMIN_SESSION_TTL_HOURS=24

# === CORS (not needed in production - frontend served from same origin) ===
CORS_ALLOWED_ORIGINS=http://localhost:8000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
