# =============================================================================
# VibePrint OS - Production Environment Configuration
# =============================================================================
# Copy to .env on the kiosk machine:  cp .env.production .env
# Then edit the values marked with [CHANGE ME].
# =============================================================================
# Settings here are DEPLOYMENT-TIME only. Runtime settings (AI, payment,
# photobooth, printer hardware, kiosk timings) are managed via the admin
# panel at http://localhost:8000/admin and stored in the database.
# =============================================================================

# === Application ===
APP_ENV=production
APP_SECRET_KEY=[CHANGE ME - generate with: python -c "import secrets; print(secrets.token_hex(32))"]
APP_DEBUG=false
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=WARNING

# === Database ===
POSTGRES_DB=thermavibe
POSTGRES_USER=thermavibe
POSTGRES_PASSWORD=[CHANGE ME - set a secure database password]

# === Admin ===
ADMIN_PIN=[CHANGE ME - set a secure PIN]
ADMIN_SESSION_TTL_HOURS=24

# === Hardware Detection (machine-specific, not in admin panel) ===
PRINTER_AUTO_DETECT=true
PRINTER_HOTPLUG_INTERVAL_SECONDS=30
CAMERA_DEVICE_INDEX=0

# === AI Provider Keys (initial seed, then managed via admin panel) ===
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# === Payment Keys (initial seed, then managed via admin panel) ===
PAYMENT_ENABLED=false
PAYMENT_PROVIDER=mock
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_API_KEY=

# === Printer Hardware (initial seed, then managed via admin panel) ===
PRINTER_VENDOR_ID=0x04b8
PRINTER_PRODUCT_ID=0x0e15
